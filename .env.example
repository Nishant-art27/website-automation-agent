# ============================================================================
# Website Automation Agent — Configuration
# Copy this file to ".env" and adjust as needed:   cp .env.example .env
# Every value below is OPTIONAL — the agent runs out of the box with defaults.
# ============================================================================

# ----------------------------------------------------------------------------
# AI BACKEND (the agent's "brain") — powered by Groq
# ----------------------------------------------------------------------------
# The agent has a pluggable brain:
#   - If GROQ_API_KEY is set  -> it uses the LLM agent (vision + tool calling).
#   - If it is NOT set        -> it falls back to the offline HEURISTIC agent.
# You can also force a mode with AGENT_MODE below.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Override the API base URL (Groq's OpenAI-compatible endpoint). Leave blank to
# use the SDK default (https://api.groq.com/openai/v1).
GROQ_BASE_URL=

# Vision + tool-use capable Groq model used by the LLM agent.
# Good options: meta-llama/llama-4-scout-17b-16e-instruct,
#               meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Send screenshots to the LLM (true) or ground it purely on the text element
# list (false). Vision uses many tokens and can exceed Groq's free-tier limit,
# so it is OFF by default. Turn on only with a vision model + higher tier.
LLM_USE_VISION=false

# Force the brain explicitly. One of: auto | llm | heuristic
#   auto (default) -> llm when an API key exists, otherwise heuristic
AGENT_MODE=auto

# ----------------------------------------------------------------------------
# TARGET TASK
# ----------------------------------------------------------------------------
# The page the agent will automate.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Values the agent will type into the detected Name and Description fields.
FIELD_NAME_VALUE=John Doe
FIELD_DESCRIPTION_VALUE=This form was filled in automatically by the Website Automation Agent — an AI-driven browser automation built on Playwright.

# ----------------------------------------------------------------------------
# BROWSER
# ----------------------------------------------------------------------------
# Show the browser window (false) or run hidden (true). Headed is great for demos.
HEADLESS=false

# Viewport size (screenshot coordinates map 1:1 to these dimensions).
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900

# Slow every Playwright action by N ms so a human can follow the demo.
SLOW_MO_MS=150

# Default timeout (ms) for navigation and element operations.
DEFAULT_TIMEOUT_MS=30000

# ----------------------------------------------------------------------------
# AGENT BEHAVIOUR
# ----------------------------------------------------------------------------
# Max reasoning/acting steps before the LLM agent gives up (safety cap).
MAX_STEPS=25

# Logging verbosity: debug | info | warn | error
LOG_LEVEL=info

# Where screenshots and the run log are written.
ARTIFACTS_DIR=artifacts
